    {
      "name": "POST Auth Login User A",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login A returns 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  const tokenA = json.accessToken || json.token;",
              "",
              "  pm.environment.set(\"tokenA\", tokenA);",
              "",
              "  pm.test(\"tokenA saved\", function () {",
              "    pm.expect(pm.environment.get(\"tokenA\")).to.be.ok;",
